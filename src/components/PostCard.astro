---
interface Props {
	slug: string;
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: string;
	tags: string[];
}

const { slug, title, description, pubDate, heroImage, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-CL', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<article class="group rounded-lg border border-slate-800 bg-slate-900/50 p-6 transition-colors hover:border-emerald-500/50">
	<a href={`/blog/${slug}`} class="block">
		{
			heroImage && (
				<img
					src={heroImage}
					alt={title}
					class="mb-4 aspect-video w-full rounded-md border border-slate-800 object-cover"
				/>
			)
		}
		<time datetime={pubDate.toISOString()} class="text-xs text-slate-500">{formattedDate}</time>
		<h2 class="mt-2 text-xl font-semibold text-white group-hover:text-emerald-400">{title}</h2>
		<p class="mt-2 text-slate-400">{description}</p>
		{
			tags.length > 0 && (
				<ul class="mt-4 flex flex-wrap gap-2">
					{tags.map((tag) => (
						<li class="rounded-full bg-emerald-500/10 px-3 py-1 text-xs text-emerald-400">
							#{tag}
						</li>
					))}
				</ul>
			)
		}
	</a>
</article>

---
import Layout from './Layout.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	author: string;
	tags: string[];
}

const { title, description, pubDate, updatedDate, author, tags } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('es-CL', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<Layout title={title} description={description}>
	<article class="mx-auto max-w-2xl px-4 py-12">
		<header class="mb-8 border-b border-slate-800 pb-8">
			<h1 class="text-3xl font-bold text-white">{title}</h1>
			<p class="mt-3 text-slate-400">{description}</p>
			<div class="mt-4 flex items-center gap-3 text-sm text-slate-500">
				<span>{author}</span>
				<span>&middot;</span>
				<time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
				{
					updatedDate && (
						<>
							<span>&middot;</span>
							<span>actualizado el {updatedDate.toLocaleDateString('es-CL')}</span>
						</>
					)
				}
			</div>
			{
				tags.length > 0 && (
					<ul class="mt-4 flex flex-wrap gap-2">
						{tags.map((tag) => (
							<li class="rounded-full bg-emerald-500/10 px-3 py-1 text-xs text-emerald-400">
								#{tag}
							</li>
						))}
					</ul>
				)
			}
		</header>
		<div class="prose prose-invert max-w-none prose-headings:text-white prose-a:text-emerald-400">
			<slot />
		</div>
	</article>
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<Layout>
	<section class="mx-auto max-w-4xl px-4 py-16 text-center">
		<h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
			Bienvenido a <span class="text-emerald-400">werex.tk</span>
		</h1>
		<p class="mx-auto mt-4 max-w-xl text-lg text-slate-400">
			Tutoriales, noticias y opiniones sobre desarrollo, sistemas y todo lo que mueve al mundo
			tech.
		</p>
		<a
			href="/blog"
			class="mt-8 inline-block rounded-md bg-emerald-500 px-6 py-3 font-semibold text-slate-950 transition-colors hover:bg-emerald-400"
		>
			Ver todos los posts
		</a>
	</section>

	<section class="mx-auto max-w-4xl px-4 pb-16">
		<h2 class="mb-6 text-2xl font-bold text-white">Últimos posts</h2>
		<div class="grid gap-6">
			{posts.map((post) => <PostCard slug={post.id} {...post.data} />)}
		</div>
	</section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Acerca de" description="Sobre Werex y este blog.">
	<section class="mx-auto max-w-2xl px-4 py-16">
		<h1 class="text-3xl font-bold text-white">Acerca de</h1>
		<div class="prose prose-invert mt-6 max-w-none prose-a:text-emerald-400">
			<p>
				Werex Blog es un espacio dedicado a la tecnología: tutoriales, noticias y opiniones
				sobre desarrollo de software, sistemas y todo lo que mueve al mundo tech.
			</p>
			<p>Creado y mantenido por Werex.</p>
		</div>
	</section>
</Layout>

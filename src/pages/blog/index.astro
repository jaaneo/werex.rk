---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog" description="Todos los posts del blog de Werex.">
	<section class="mx-auto max-w-4xl px-4 py-16">
		<h1 class="text-3xl font-bold text-white">Blog</h1>
		<p class="mt-2 text-slate-400">Todos los artículos publicados.</p>

		<div class="mt-10 grid gap-6">
			{posts.map((post) => <PostCard slug={post.id} {...post.data} />)}
		</div>
	</section>
</Layout>
